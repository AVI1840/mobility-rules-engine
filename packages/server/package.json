{
  "name": "@mobility-rules-engine/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Rules engine server — Express.js + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "tunnel": "npx ngrok http 3001",
    "build": "tsc && node -e \"const{cpSync}=require('fs');cpSync('schemas','dist/schemas',{recursive:true});cpSync('data','dist/data',{recursive:true})\"",
    "start:prod": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/uuid": "^10.0.0",
    "fast-check": "^3.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
