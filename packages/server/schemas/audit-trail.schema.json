{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AuditTrail",
  "description": "Immutable audit record for every eligibility evaluation",
  "type": "object",
  "required": ["audit_id", "request_id", "claimant_id", "processing_timestamp", "evaluated_rules", "conflicts", "final_decision", "reasoning_chain", "immutable"],
  "additionalProperties": false,
  "properties": {
    "audit_id": { "type": "string", "format": "uuid" },
    "request_id": { "type": "string", "format": "uuid" },
    "claimant_id": { "type": "string", "minLength": 1 },
    "processing_timestamp": { "type": "string", "format": "date-time" },
    "evaluated_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "rule_version", "input_values", "evaluation_result", "legal_citation", "evaluation_order", "evaluation_time_ms"],
        "additionalProperties": false,
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "rule_version": { "type": "string", "minLength": 1 },
          "input_values": { "type": "object" },
          "evaluation_result": { "type": "string", "minLength": 1 },
          "legal_citation": {
            "type": "object",
            "required": ["document_name", "section", "paragraph"],
            "additionalProperties": false,
            "properties": {
              "document_name": { "type": "string", "minLength": 1 },
              "section": { "type": "string", "minLength": 1 },
              "paragraph": { "type": "string", "minLength": 1 },
              "clause": { "type": ["string", "null"] }
            }
          },
          "evaluation_order": { "type": "integer", "minimum": 1 },
          "evaluation_time_ms": { "type": "number", "minimum": 0 }
        }
      }
    },
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conflicting_rule_ids", "winning_rule_id", "resolution_method", "legal_basis"],
        "additionalProperties": false,
        "properties": {
          "conflicting_rule_ids": { "type": "array", "items": { "type": "string" } },
          "winning_rule_id": { "type": "string", "minLength": 1 },
          "resolution_method": { "type": "string", "minLength": 1 },
          "legal_basis": { "type": "string", "minLength": 1 }
        }
      }
    },
    "final_decision": { "type": "string", "minLength": 1 },
    "reasoning_chain": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "description", "result"],
        "additionalProperties": false,
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "description": { "type": "string", "minLength": 1 },
          "rule_id": { "type": "string" },
          "result": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence_validation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "items_checked": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["evidence_type", "status", "legal_requirement"],
            "additionalProperties": false,
            "properties": {
              "evidence_type": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["present", "missing", "stale", "contradictory"] },
              "legal_requirement": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "immutable": { "type": "boolean", "const": true }
  }
}
