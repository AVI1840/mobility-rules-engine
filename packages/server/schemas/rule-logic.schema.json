{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RuleDefinition",
  "description": "A machine-executable rule definition with legal citation and decision tree",
  "type": "object",
  "required": ["rule_id", "rule_name", "source_document_id", "source_section", "effective_date", "priority", "conditions", "actions", "legal_citation", "discretionary_flag"],
  "additionalProperties": false,
  "definitions": {
    "Condition": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["AND", "OR", "NOT", "COMPARISON", "EXISTS"] },
        "operands": { "type": "array", "items": { "$ref": "#/definitions/Condition" } },
        "variable": { "type": "string" },
        "operator": { "type": "string", "enum": ["eq", "neq", "gt", "gte", "lt", "lte", "in", "not_in", "between"] },
        "value": {}
      }
    },
    "LegalCitation": {
      "type": "object",
      "required": ["document_name", "section", "paragraph"],
      "additionalProperties": false,
      "properties": {
        "document_name": { "type": "string", "minLength": 1 },
        "section": { "type": "string", "minLength": 1 },
        "paragraph": { "type": "string", "minLength": 1 },
        "clause": { "type": ["string", "null"] }
      }
    },
    "DecisionTreeNode": {
      "type": "object",
      "required": ["node_id", "node_type"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "string", "minLength": 1 },
        "node_type": { "type": "string", "enum": ["condition", "leaf"] },
        "condition": { "$ref": "#/definitions/Condition" },
        "true_branch": { "$ref": "#/definitions/DecisionTreeNode" },
        "false_branch": { "$ref": "#/definitions/DecisionTreeNode" },
        "outcome": { "type": "string", "enum": ["eligible", "not_eligible", "requires_discretion", "requires_additional_information"] },
        "legal_citation": { "$ref": "#/definitions/LegalCitation" },
        "depth": { "type": "integer", "minimum": 0, "maximum": 50 }
      }
    }
  },
  "properties": {
    "rule_id": { "type": "string", "format": "uuid" },
    "rule_name": { "type": "string", "minLength": 1 },
    "source_document_id": { "type": "string", "minLength": 1 },
    "source_section": { "type": "string", "minLength": 1 },
    "effective_date": { "type": "string", "format": "date" },
    "expiry_date": { "type": ["string", "null"], "format": "date" },
    "priority": { "type": "string", "enum": ["judicial_override", "statutory", "circular", "procedural"] },
    "conditions": { "$ref": "#/definitions/Condition" },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["action_type"],
        "additionalProperties": false,
        "properties": {
          "action_type": { "type": "string", "enum": ["determine_eligibility", "calculate_amount", "refer_to_review", "require_additional_info"] },
          "parameters": { "type": "object" }
        }
      }
    },
    "legal_citation": { "$ref": "#/definitions/LegalCitation" },
    "discretionary_flag": { "type": "boolean" },
    "discretionary_reason": { "type": ["string", "null"] },
    "decision_tree": { "$ref": "#/definitions/DecisionTreeNode" }
  }
}
