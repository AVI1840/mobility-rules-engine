  },
  "actions": [
    {
      "action_type": "calculate_amount",
      "parameters": {
        "calculation_type": "loan_rate",
        "note": "שיעור ההלוואה: בעל רישיון 80%+ = 100%, בעל רישיון 40-79% = אחוז המוגבלות, ללא רישיון 80%+ = 75%, ללא רישיון 60-79% = 75% כפול אחוז המוגבלות",
        "rules": [
          { "condition": "driver_license AND disability >= 80", "rate": "100%" },
          { "condition": "driver_license AND disability 40-79", "rate": "disability_percentage%" },
          { "condition": "no_license AND disability >= 80", "rate": "75%" },
          { "condition": "no_license AND disability 60-79", "rate": "75% * disability_percentage%" }
        ]
      }
    }
  ],
