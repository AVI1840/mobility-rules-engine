      "parameters": {
        "calculation_type": "qualifying_vehicle",
        "note": "רכב קובע נקבע לפי תוספת ג': בעל רישיון 80%+ = 1800 סמ\"ק, בעל רישיון 40-79% = 1300 סמ\"ק, ללא רישיון 60-100% = 1300 סמ\"ק, רכב משותף מתחת ל-18 = 1800 סמ\"ק",
        "rules": [
          { "condition": "driver_license_holder AND disability_percentage >= 80", "engine_volume": 1800 },
          { "condition": "driver_license_holder AND disability_percentage 40-79", "engine_volume": 1300 },
          { "condition": "NOT driver_license_holder AND disability_percentage >= 60", "engine_volume": 1300 },
          { "condition": "shared_vehicle AND age < 18", "engine_volume": 1800 }
        ]
      }
    }
